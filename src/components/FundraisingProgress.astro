---
/**
 * FundraisingProgress — Reusable progress bar for charity fundraising.
 *
 * Props:
 *   charity   – 'uk' | 'es'
 *   variant   – 'compact' (index page) | 'full' (our-progress / donate pages)
 *   showLink  – Show "Donate Now" link (default: false)
 */
import { charities, getProgress, formatCurrency, type CharityKey } from '../lib/fundraising';
import { t, defaultLang } from '../i18n/index';

interface Props {
  charity: CharityKey;
  variant?: 'compact' | 'full';
  showLink?: boolean;
}

const { charity, variant = 'full', showLink = false } = Astro.props;

const data = charities[charity];
const progress = getProgress(data.raised, data.target);
const raisedDisplay = formatCurrency(data.raised, data.currency, data.locale);
const targetDisplay = formatCurrency(data.target, data.currency, data.locale);

const labelKey = charity === 'uk' ? 'gbsGlobals.ukTarget' : 'gbsGlobals.esTarget';
const charityNameKey = charity === 'uk' ? 'gbsGlobals.heroTrustUk' : 'gbsGlobals.heroTrustEs';
const raisedAmount = data.raised.toLocaleString(data.locale, { maximumFractionDigits: 0 });
const barColor = progress >= 100 ? 'bg-emerald-500' : 'bg-amber-500';
---

{variant === 'compact' ? (
  <!-- Compact: label + target value + progress bar with raised amount inside -->
  <div>
    <p class="text-stone-500 text-xs font-body uppercase tracking-wider" data-i18n={charity === 'uk' ? 'home.ukTarget' : 'home.spainTarget'}>
      {t(defaultLang, charity === 'uk' ? 'home.ukTarget' : 'home.spainTarget')}
    </p>
    <p class="font-display text-3xl font-bold text-stone-100 mt-2">
      {targetDisplay}
    </p>
    <div class="mt-3 relative h-6 bg-stone-800 rounded-full overflow-hidden">
      <div class:list={['h-full rounded-full transition-all duration-1000', barColor]} style={`width: ${progress}%;`}></div>
      <span class="absolute inset-y-0 left-3 flex items-center text-xs font-body font-semibold text-stone-200">
        {raisedAmount}
      </span>
    </div>
  </div>
) : (
  <!-- Full: charity name + target + progress bar with raised amount inside + optional link -->
  <div>
    <p class="text-stone-400 font-body text-sm" data-i18n={charity === 'uk' ? 'progress.ukCharity' : 'progress.esCharity'}>
      {t(defaultLang, charityNameKey)}
    </p>
    <p class="text-stone-500 text-sm font-body mt-2" data-i18n={labelKey}>
      {t(defaultLang, labelKey)}
    </p>
    <div class="mt-4 relative h-6 bg-stone-800 rounded-full overflow-hidden">
      <div class:list={['h-full rounded-full transition-all duration-1000', barColor]} style={`width: ${progress}%;`}></div>
      <span class="absolute inset-y-0 left-3 flex items-center text-xs font-body font-semibold text-stone-200">
        {raisedAmount}
      </span>
    </div>
    {showLink && (
      <a href="/donate" data-track-event="Progress Donate Click" data-track-props={JSON.stringify({ charity })} class="inline-flex items-center gap-2 text-amber-400 font-body text-sm mt-4 hover:text-amber-300 transition-colors" data-i18n="progress.donateNow">
        {t(defaultLang, 'progress.donateNow')}
      </a>
    )}
  </div>
)}
