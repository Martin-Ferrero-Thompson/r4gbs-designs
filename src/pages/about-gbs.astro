---
import PageLayout from "../layouts/PageLayout.astro";
import { t, defaultLang } from "../i18n";
---

<PageLayout
  title={t(defaultLang, 'aboutGbs.pageTitle')}
  heroTitle={t(defaultLang, 'aboutGbs.heroTitle')}
  heroSubtitle={t(defaultLang, 'aboutGbs.heroSubtitle')}
  heroTitleKey="aboutGbs.heroTitle"
  heroSubtitleKey="aboutGbs.heroSubtitle"
>
  <section>
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-32">
      <div class="grid lg:grid-cols-12 gap-16">
        <!-- Main content -->
        <div class="lg:col-span-7">
          <div class="space-y-16">
            <!-- What is GBS -->
            <div>
              <h2
                class="font-display text-3xl lg:text-4xl font-bold text-stone-100"
                data-i18n="aboutGbs.whatTitle"
              >{t(defaultLang, 'aboutGbs.whatTitle')}</h2>
              <div class="mt-6 space-y-4">
                <p
                  class="text-stone-400 text-lg leading-relaxed font-body"
                  data-i18n="aboutGbs.whatDesc1"
                >{t(defaultLang, 'aboutGbs.whatDesc1')}</p>
                <p
                  class="text-stone-400 text-lg leading-relaxed font-body"
                  data-i18n="aboutGbs.whatDesc2"
                >{t(defaultLang, 'aboutGbs.whatDesc2')}</p>
                <div
                  class="bg-stone-900 rounded-xl p-6 border border-stone-800 space-y-4"
                >
                  <div class="flex gap-4 items-start">
                    <span
                      class="bg-amber-500 text-stone-950 w-8 h-8 rounded-full flex items-center justify-center font-body font-bold text-sm shrink-0"
                      >1</span
                    >
                    <p
                      class="text-stone-300 font-body"
                      data-i18n="aboutGbs.step1"
                    >{t(defaultLang, 'aboutGbs.step1')}</p>
                  </div>
                  <div class="flex gap-4 items-start">
                    <span
                      class="bg-amber-500 text-stone-950 w-8 h-8 rounded-full flex items-center justify-center font-body font-bold text-sm shrink-0"
                      >2</span
                    >
                    <p
                      class="text-stone-300 font-body"
                      data-i18n="aboutGbs.step2"
                    >{t(defaultLang, 'aboutGbs.step2')}</p>
                  </div>
                  <div class="flex gap-4 items-start">
                    <span
                      class="bg-amber-500 text-stone-950 w-8 h-8 rounded-full flex items-center justify-center font-body font-bold text-sm shrink-0"
                      >3</span
                    >
                    <p
                      class="text-stone-300 font-body"
                      data-i18n="aboutGbs.step3"
                    >{t(defaultLang, 'aboutGbs.step3')}</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- How it affects -->
            <div>
              <h2
                class="font-display text-3xl lg:text-4xl font-bold text-stone-100"
                data-i18n="aboutGbs.howTitle"
              >{t(defaultLang, 'aboutGbs.howTitle')}</h2>
              <div class="mt-6 space-y-4">
                <p
                  class="text-stone-400 text-lg leading-relaxed font-body"
                  data-i18n="aboutGbs.howDesc1"
                >{t(defaultLang, 'aboutGbs.howDesc1')}</p>
                <p
                  class="text-stone-400 text-lg leading-relaxed font-body"
                  data-i18n="aboutGbs.howDesc2"
                >{t(defaultLang, 'aboutGbs.howDesc2')}</p>
                <p
                  class="text-stone-400 text-lg leading-relaxed font-body"
                  data-i18n="aboutGbs.howDesc3"
                >{t(defaultLang, 'aboutGbs.howDesc3')}</p>
              </div>
            </div>

            <!-- Treatment -->
            <div>
              <h2
                class="font-display text-3xl lg:text-4xl font-bold text-stone-100"
                data-i18n="aboutGbs.treatmentTitle"
              >{t(defaultLang, 'aboutGbs.treatmentTitle')}</h2>
              <div class="mt-6 space-y-4">
                <p
                  class="text-stone-400 text-lg leading-relaxed font-body"
                  data-i18n="aboutGbs.treatmentDesc1"
                >{t(defaultLang, 'aboutGbs.treatmentDesc1')}</p>
                <div class="grid sm:grid-cols-2 gap-4">
                  <div
                    class="bg-stone-900 rounded-xl p-6 border border-stone-800"
                  >
                    <h4
                      class="font-display text-lg font-bold text-amber-400"
                      data-i18n="aboutGbs.ivigTitle"
                    >{t(defaultLang, 'aboutGbs.ivigTitle')}</h4>
                    <p
                      class="text-stone-400 text-sm mt-2 font-body"
                      data-i18n="aboutGbs.ivigDesc"
                    >{t(defaultLang, 'aboutGbs.ivigDesc')}</p>
                  </div>
                  <div
                    class="bg-stone-900 rounded-xl p-6 border border-stone-800"
                  >
                    <h4
                      class="font-display text-lg font-bold text-amber-400"
                      data-i18n="aboutGbs.plasmaTitle"
                    >{t(defaultLang, 'aboutGbs.plasmaTitle')}</h4>
                    <p
                      class="text-stone-400 text-sm mt-2 font-body"
                      data-i18n="aboutGbs.plasmaDesc"
                    >{t(defaultLang, 'aboutGbs.plasmaDesc')}</p>
                  </div>
                </div>
                <p
                  class="text-stone-400 text-lg leading-relaxed font-body"
                  data-i18n="aboutGbs.treatmentDesc2"
                >{t(defaultLang, 'aboutGbs.treatmentDesc2')}</p>
              </div>
            </div>

            <!-- Find out more -->
            <div>
              <h2
                class="font-display text-3xl lg:text-4xl font-bold text-stone-100"
                data-i18n="aboutGbs.findOutMoreTitle"
              >{t(defaultLang, 'aboutGbs.findOutMoreTitle')}</h2>
              <div class="mt-6 space-y-4">
                <p
                  class="text-stone-400 text-lg leading-relaxed font-body"
                  data-i18n="aboutGbs.findOutMoreDesc"
                >{t(defaultLang, 'aboutGbs.findOutMoreDesc')}</p>
                <p
                  class="text-stone-400 text-lg leading-relaxed font-body"
                  data-i18n="aboutGbs.findOutMoreDesc2"
                >{t(defaultLang, 'aboutGbs.findOutMoreDesc2')}</p>
                <a
                  class="text-amber-400 underline hover:text-amber-300 transition-colors"
                  data-i18n-href="aboutGbs.findOutMoreUrl"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span data-i18n="aboutGbs.findOutMoreLink">{t(defaultLang, 'aboutGbs.findOutMoreLink')}</span>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-5">
          <div class="lg:sticky lg:top-28 space-y-6">
            <!-- Key facts -->
            <div class="bg-stone-900 rounded-2xl p-8 border border-stone-800">
              <h3
                class="font-display text-xl font-bold text-stone-100 mb-6"
                data-i18n="aboutGbs.keyFacts"
              >{t(defaultLang, 'aboutGbs.keyFacts')}</h3>
              <div class="space-y-6">
                <div>
                  <p
                    class="font-display text-3xl font-bold text-amber-400"
                    data-i18n="aboutGbs.fact1Value"
                  >{t(defaultLang, 'aboutGbs.fact1Value')}</p>
                  <p
                    class="text-stone-500 text-sm mt-1 font-body"
                    data-i18n="aboutGbs.fact1Label"
                  >{t(defaultLang, 'aboutGbs.fact1Label')}</p>
                </div>
                <div class="h-px bg-stone-800"></div>
                <div>
                  <p
                    class="font-display text-3xl font-bold text-amber-400"
                    data-i18n="aboutGbs.fact2Value"
                  >{t(defaultLang, 'aboutGbs.fact2Value')}</p>
                  <p
                    class="text-stone-500 text-sm mt-1 font-body"
                    data-i18n="aboutGbs.fact2Label"
                  >{t(defaultLang, 'aboutGbs.fact2Label')}</p>
                </div>
                <div class="h-px bg-stone-800"></div>
                <div>
                  <p
                    class="font-display text-3xl font-bold text-amber-400"
                    data-i18n="aboutGbs.fact3Value"
                  >{t(defaultLang, 'aboutGbs.fact3Value')}</p>
                  <p
                    class="text-stone-500 text-sm mt-1 font-body"
                    data-i18n="aboutGbs.fact3Label"
                  >{t(defaultLang, 'aboutGbs.fact3Label')}</p>
                </div>
                <div class="h-px bg-stone-800"></div>
                <div>
                  <p
                    class="font-display text-3xl font-bold text-amber-400"
                    data-i18n="aboutGbs.fact4Value"
                  >{t(defaultLang, 'aboutGbs.fact4Value')}</p>
                  <p
                    class="text-stone-500 text-sm mt-1 font-body"
                    data-i18n="aboutGbs.fact4Label"
                  >{t(defaultLang, 'aboutGbs.fact4Label')}</p>
                </div>
              </div>
            </div>

            <!-- Our charities -->
            <div
              class="bg-amber-500/10 rounded-2xl p-8 border border-amber-500/20"
            >
              <h3
                class="font-display text-xl font-bold text-amber-400 mb-4"
                data-i18n="aboutGbs.supportingResearch"
              >{t(defaultLang, 'aboutGbs.supportingResearch')}</h3>
              <p
                class="text-stone-400 text-sm font-body leading-relaxed"
                data-i18n="aboutGbs.supportingDesc"
              >{t(defaultLang, 'aboutGbs.supportingDesc')}</p>
              <a
                href="/donate"
                class="inline-flex items-center gap-2 bg-amber-500 text-stone-950 px-6 py-3 rounded-full font-body font-bold text-sm mt-6 hover:bg-amber-400 transition-colors"
                data-i18n="aboutGbs.donateToResearch"
              >{t(defaultLang, 'aboutGbs.donateToResearch')}</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
