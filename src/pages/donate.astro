---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Donate"
  heroTitle="Support Patient-Led Research"
  heroSubtitle="100% of every donation goes directly to our partner charities supporting GBS research and patient care."
  heroTitleKey="donate.heroTitle"
  heroSubtitleKey="donate.heroSubtitle"
>
  <section>
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-32">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">

        <!-- UK Charity -->
        <div class="bg-stone-900 rounded-3xl p-8 lg:p-12 border border-stone-800">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-3 h-3 bg-amber-500 rounded-full"></div>
            <span class="text-stone-400 font-body text-sm" data-i18n="donate.ukRegion"></span>
          </div>
          <h2 class="font-display text-2xl lg:text-3xl font-bold text-stone-100" data-i18n="donate.ukCharityName"></h2>
          <p class="text-stone-400 text-lg leading-relaxed font-body mt-4" data-i18n="donate.ukDesc"></p>

          <div class="mt-8 bg-stone-800/50 rounded-xl p-6">
            <p class="text-stone-500 text-sm font-body" data-i18n="donate.ukHelp"></p>
            <ul class="mt-3 space-y-2">
              <li class="flex items-start gap-3">
                <span class="text-amber-500 mt-1">•</span>
                <span class="text-stone-300 text-sm font-body" data-i18n="donate.ukHelp1"></span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-amber-500 mt-1">•</span>
                <span class="text-stone-300 text-sm font-body" data-i18n="donate.ukHelp2"></span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-amber-500 mt-1">•</span>
                <span class="text-stone-300 text-sm font-body" data-i18n="donate.ukHelp3"></span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-amber-500 mt-1">•</span>
                <span class="text-stone-300 text-sm font-body" data-i18n="donate.ukHelp4"></span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-amber-500 mt-1">•</span>
                <span class="text-stone-300 text-sm font-body" data-i18n="donate.ukHelp5"></span>
              </li>
            </ul>
          </div>

          <!-- Funds raised -->
          <div class="mt-8">
            <div class="flex justify-between items-baseline">
              <p class="font-display text-3xl font-bold text-stone-100">£0</p>
              <p class="text-stone-500 font-body text-sm" data-i18n="donate.ukTarget"></p>
            </div>
            <div class="mt-3 h-2 bg-stone-800 rounded-full overflow-hidden">
              <div class="h-full bg-amber-500 rounded-full" style="width: 0%;"></div>
            </div>
            <p class="text-stone-600 text-xs font-body mt-2" data-i18n="donate.ukGiftAid"></p>
          </div>

          <div class="mt-8 p-6 bg-stone-800/30 rounded-xl border border-stone-700/50 text-center">
            <p class="text-stone-300 font-body" data-i18n="donate.comingSoon"></p>
            <p class="text-stone-500 text-xs font-body mt-2" data-i18n="donate.comingSoonDesc"></p>
          </div>
        </div>

        <!-- Spain Charity -->
        <div class="bg-stone-900 rounded-3xl p-8 lg:p-12 border border-stone-800">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-3 h-3 bg-amber-500 rounded-full"></div>
            <span class="text-stone-400 font-body text-sm" data-i18n="donate.esRegion"></span>
          </div>
          <h2 class="font-display text-2xl lg:text-3xl font-bold text-stone-100" data-i18n="donate.esCharityName"></h2>
          <p class="text-stone-400 text-lg leading-relaxed font-body mt-4" data-i18n="donate.esDesc"></p>

          <div class="mt-8 bg-stone-800/50 rounded-xl p-6">
            <p class="text-stone-500 text-sm font-body" data-i18n="donate.esHelp"></p>
            <ul class="mt-3 space-y-2">
              <li class="flex items-start gap-3">
                <span class="text-amber-500 mt-1">•</span>
                <span class="text-stone-300 text-sm font-body" data-i18n="donate.esHelp1"></span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-amber-500 mt-1">•</span>
                <span class="text-stone-300 text-sm font-body" data-i18n="donate.esHelp2"></span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-amber-500 mt-1">•</span>
                <span class="text-stone-300 text-sm font-body" data-i18n="donate.esHelp3"></span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-amber-500 mt-1">•</span>
                <span class="text-stone-300 text-sm font-body" data-i18n="donate.esHelp4"></span>
              </li>
            </ul>
          </div>

          <!-- Funds raised -->
          <div class="mt-8">
            <div class="flex justify-between items-baseline">
              <p class="font-display text-3xl font-bold text-stone-100">€0</p>
              <p class="text-stone-500 font-body text-sm" data-i18n="donate.esTarget"></p>
            </div>
            <div class="mt-3 h-2 bg-stone-800 rounded-full overflow-hidden">
              <div class="h-full bg-amber-500 rounded-full" style="width: 0%;"></div>
            </div>
          </div>

          <div class="mt-8 p-6 bg-stone-800/30 rounded-xl border border-stone-700/50 text-center">
            <p class="text-stone-300 font-body" data-i18n="donate.comingSoon"></p>
            <p class="text-stone-500 text-xs font-body mt-2" data-i18n="donate.comingSoonDesc"></p>
          </div>
        </div>
      </div>

      <!-- Important note -->
      <div class="mt-12 text-center">
        <div class="inline-flex items-center gap-2 bg-amber-500/10 border border-amber-500/20 rounded-full px-6 py-3">
          <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <p class="text-amber-400 text-sm font-body" data-i18n-html="donate.supportNote"></p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
