---
/**
 * VERSION 1: CINEMATIC NOIR
 * ─────────────────────────
 * Dark, dramatic, full-bleed. Amber accents cut through volcanic blacks.
 * Think: documentary film poster meets luxury sports brand.
 * Typography: Massive Playfair Display headlines, whisper-thin DM Sans body.
 * Motion: Orchestrated page-load reveal with staggered cinematic timing.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Countdown from '../components/Countdown.tsx';
import { t, defaultLang } from '../i18n/index';
---

<BaseLayout title={t(defaultLang, 'home.heroTitleLine1') + ' ' + t(defaultLang, 'home.heroTitleLine2') + ' ' + t(defaultLang, 'home.heroTitleLine3') + ' | Riding4GBS'}>
  <Navigation />

  <!-- ═══ HERO: FULL VIEWPORT CINEMATIC ═══ -->
  <section class="relative min-h-screen flex items-end bg-stone-950 overflow-hidden">
    <!-- Gradient overlay simulating mountain horizon at dusk -->
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-b from-stone-950 via-stone-900/80 to-stone-950"></div>
      <!-- Subtle mountain silhouette via CSS -->
      <div class="absolute bottom-0 left-0 right-0 h-[40vh]" style="background: linear-gradient(165deg, transparent 30%, #292524 30.5%, #292524 35%, transparent 35.5%), linear-gradient(195deg, transparent 25%, #1c1917 25.5%, #1c1917 45%, transparent 45.5%), linear-gradient(175deg, transparent 40%, #292524 40.5%);opacity:0.3;"></div>
      <!-- Animated gradient shimmer -->
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-amber-500/5 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-1/3 right-1/4 w-64 h-64 bg-amber-500/3 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
    </div>

    <div class="relative z-10 max-w-[1400px] mx-auto px-6 lg:px-10 pb-20 lg:pb-32 pt-32 w-full">
      <!-- ═══ Hashtag marker ═══ -->
      <div class="animate-fade-up">
        <span class="inline-block text-amber-500/80 font-body text-xs tracking-[0.35em] uppercase mb-6" data-i18n="home.heroTag">
          {t(defaultLang, 'home.heroTag')}
        </span>
      </div>

      <!-- ═══ Main headline - massive, cinematic ═══ -->
      <h1 class="font-display text-5xl sm:text-7xl lg:text-[8rem] xl:text-[10rem] font-black leading-[0.85] tracking-tight text-stone-100 animate-fade-up stagger-1" data-i18n="home.heroTitle">
        <span data-i18n="home.heroTitleLine1">{t(defaultLang, 'home.heroTitleLine1')}</span><br/>
        <span class="text-amber-400" data-i18n="home.heroTitleLine2">{t(defaultLang, 'home.heroTitleLine2')}</span> <span data-i18n="home.heroTitleLine3">{t(defaultLang, 'home.heroTitleLine3')}</span>
      </h1>

      <!-- ═══ Subheadline ═══ -->
      <div class="mt-8 lg:mt-12 max-w-2xl animate-fade-up stagger-3">
        <p class="text-stone-400 text-lg lg:text-xl leading-relaxed font-body" data-i18n="home.heroSubtitle">
          {t(defaultLang, 'home.heroSubtitle')}
        </p>
      </div>

      <!-- ═══ CTA cluster ═══ -->
      <div class="mt-10 lg:mt-14 flex flex-wrap gap-4 animate-fade-up stagger-4">
        <a href="/the-challenge" class="group inline-flex items-center gap-3 bg-amber-500 text-stone-950 px-8 py-4 rounded-full font-body font-bold text-sm tracking-wide hover:bg-amber-400 transition-all duration-300 hover:gap-4">
          <span data-i18n="home.discoverChallenge">{t(defaultLang, 'home.discoverChallenge')}</span>
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/donate" class="inline-flex items-center gap-2 border border-stone-600 text-stone-300 px-8 py-4 rounded-full font-body text-sm tracking-wide hover:border-amber-500 hover:text-amber-400 transition-all duration-300" data-i18n="home.donateToResearch">
          {t(defaultLang, 'home.donateToResearch')}
        </a>
      </div>

      <!-- ═══ Charity trust strip ═══ -->
      <div class="mt-8 animate-fade-up stagger-4">
        <p class="text-stone-600 font-body text-xs tracking-[0.2em] uppercase mb-3" data-i18n="home.heroTrustLabel">{t(defaultLang, 'home.heroTrustLabel')}</p>
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-8">
          <a href="https://www.inflammatoryneuropathies.uk/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 group">
            <span class="text-lg leading-none">🇬🇧</span>
            <div>
              <p class="text-stone-300 font-body text-sm group-hover:text-amber-400 transition-colors" data-i18n="home.heroTrustUk">{t(defaultLang, 'home.heroTrustUk')}</p>
              <p class="text-stone-600 font-body text-xs" data-i18n="home.heroTrustUkReg">{t(defaultLang, 'home.heroTrustUkReg')}</p>
            </div>
          </a>
          <a href="https://gbs-cidp.org.es/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 group">
            <span class="text-lg leading-none">🇪🇸</span>
            <div>
              <p class="text-stone-300 font-body text-sm group-hover:text-amber-400 transition-colors" data-i18n="home.heroTrustEs">{t(defaultLang, 'home.heroTrustEs')}</p>
              <p class="text-stone-600 font-body text-xs" data-i18n="home.heroTrustEsReg">{t(defaultLang, 'home.heroTrustEsReg')}</p>
            </div>
          </a>
        </div>
      </div>

      <!-- ═══ Countdown ═══ -->
      <div class="mt-12 animate-fade-up stagger-5">
        <p class="text-stone-500 font-body text-xs tracking-[0.3em] uppercase mb-4" data-i18n="countdown.challengeBeginsIn">{t(defaultLang, 'countdown.challengeBeginsIn')}</p>
        <Countdown client:load targetDate="2026-09-27T09:00:00" />
      </div>

      <!-- ═══ Stats ribbon ═══ -->
      <div class="mt-16 lg:mt-24 grid grid-cols-2 lg:grid-cols-4 gap-8 animate-fade-up stagger-6">
        <div class="border-l-2 border-amber-500/40 pl-4">
          <p class="font-display text-3xl lg:text-4xl font-bold text-stone-100" data-i18n="stats.targetDays">{t(defaultLang, 'stats.targetDays')}</p>
          <p class="text-stone-500 text-sm mt-1 font-body" data-i18n="stats.days">{t(defaultLang, 'stats.days')}</p>
        </div>
        <div class="border-l-2 border-amber-500/40 pl-4">
          <p class="font-display text-3xl lg:text-4xl font-bold text-stone-100" data-i18n="stats.targetKilometres">{t(defaultLang, 'stats.targetKilometres')}</p>
          <p class="text-stone-500 text-sm mt-1 font-body" data-i18n="stats.kilometres">{t(defaultLang, 'stats.kilometres')}</p>
        </div>
        <div class="border-l-2 border-amber-500/40 pl-4">
          <p class="font-display text-3xl lg:text-4xl font-bold text-stone-100" data-i18n="stats.targetMetresClimbed">{t(defaultLang, 'stats.targetMetresClimbed')}</p>
          <p class="text-stone-500 text-sm mt-1 font-body" data-i18n="stats.metresClimbed">{t(defaultLang, 'stats.metresClimbed')}</p>
        </div>
        <div class="border-l-2 border-amber-500/40 pl-4">
          <p class="font-display text-3xl lg:text-4xl font-bold text-stone-100" data-i18n="stats.targetEverestSummits">{t(defaultLang, 'stats.targetEverestSummits')}</p>
          <p class="text-stone-500 text-sm mt-1 font-body" data-i18n="stats.heightOfEverest">{t(defaultLang, 'stats.heightOfEverest')}</p>
        </div>
      </div>
    </div>

  </section>

  <!-- ═══ MISSION STATEMENT ═══ -->
  <section class="bg-stone-950 relative">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-40">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-5">
          <span class="text-amber-500 font-body text-xs tracking-[0.3em] uppercase" data-i18n="home.missionTag">{t(defaultLang, 'home.missionTag')}</span>
          <h2 class="font-display text-4xl lg:text-6xl font-bold text-stone-100 mt-4 leading-tight">
            {t(defaultLang, 'home.missionTitle1')}<br/>{t(defaultLang, 'home.missionTitle2')}
          </h2>
        </div>
        <div class="lg:col-span-7 lg:pt-12">
          <p class="text-stone-400 text-lg lg:text-xl leading-relaxed max-w-2xl font-body" data-i18n="home.missionDesc">{t(defaultLang, 'home.missionDesc')}</p>
          <p class="text-stone-500 text-lg leading-relaxed max-w-2xl mt-6 font-body" data-i18n="home.missionDesc2">{t(defaultLang, 'home.missionDesc2')}</p>
          <a href="/our-story" class="inline-flex items-center gap-2 text-amber-400 font-body text-sm mt-8 hover:text-amber-300 transition-colors group">
            <span data-i18n="home.readFullStory">{t(defaultLang, 'home.readFullStory')}</span>
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ THE CHALLENGE PREVIEW ═══ -->
  <section class="bg-stone-900 relative overflow-hidden">
    <!-- ═══Diagonal amber accent line ═══ -->
    <div class="absolute top-0 right-0 w-1 h-full bg-gradient-to-b from-amber-500/0 via-amber-500/30 to-amber-500/0"></div>

    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-40">
      <div class="text-center mb-16 lg:mb-24">
        <span class="text-amber-500 font-body text-xs tracking-[0.3em] uppercase" data-i18n="home.challengeTag">{t(defaultLang, 'home.challengeTag')}</span>
        <h2 class="font-display text-4xl lg:text-6xl font-bold text-stone-100 mt-4" data-i18n="home.challengeTitle">
          {t(defaultLang, 'home.challengeTitle')}
        </h2>
        <p class="text-stone-400 text-lg mt-6 max-w-2xl mx-auto font-body" data-i18n="home.challengeDesc">
          {t(defaultLang, 'home.challengeDesc')}
        </p>
      </div>

      <!-- ═══ Route cards ═══ -->
      <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
        <!-- The Start -->
        <div class="group relative bg-stone-800/50 rounded-2xl p-8 lg:p-12 border border-stone-700/50 hover:border-amber-500/30 transition-all duration-500">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-amber-500 to-transparent rounded-t-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <span class="text-amber-500/60 font-display text-6xl lg:text-8xl font-bold absolute top-4 right-6 opacity-20" data-i18n="theChallenge.theStartNum">{t(defaultLang, 'theChallenge.theStartNum')}</span>
          <h3 class="font-display text-2xl lg:text-3xl font-bold text-stone-100 relative" data-i18n="theChallenge.theStartTitle">{t(defaultLang, 'theChallenge.theStartTitle')}</h3>
                    {t(defaultLang, 'theChallenge.theStartTitle')}
          <p class="text-stone-400 mt-4 leading-relaxed font-body relative" data-i18n="theChallenge.theStartDesc">
            {t(defaultLang, 'theChallenge.theStartDesc')}
          </p>
          <div class="mt-6 flex gap-4 relative">
            <span class="text-xs font-body bg-stone-700/50 text-stone-300 px-3 py-1 rounded-full" data-i18n="theChallenge.theStartDirection">{t(defaultLang, 'theChallenge.theStartDirection')}</span>
            <span class="text-xs font-body bg-stone-700/50 text-stone-300 px-3 py-1 rounded-full"data-i18n="theChallenge.theStartDistance">{t(defaultLang, 'theChallenge.theStartDistance')}</span>
          </div>
        </div>

        <!-- The Climbing -->
        <div class="group relative bg-stone-800/50 rounded-2xl p-8 lg:p-12 border border-stone-700/50 hover:border-amber-500/30 transition-all duration-500">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-amber-500 to-transparent rounded-t-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <span class="text-amber-500/60 font-display text-6xl lg:text-8xl font-bold absolute top-4 right-6 opacity-20">02</span>
          <h3 class="font-display text-2xl lg:text-3xl font-bold text-stone-100 relative" data-i18n="home.spanishTitle">The Climbing</h3>
                    {t(defaultLang, 'home.spanishTitle')}
          <p class="text-stone-400 mt-4 leading-relaxed font-body relative" data-i18n="home.spanishDesc">
            {t(defaultLang, 'home.spanishDesc')}
          </p>
          <div class="mt-6 flex gap-4 relative">
            <span class="text-xs font-body bg-stone-700/50 text-stone-300 px-3 py-1 rounded-full" data-i18n="home.spanishDir">Mediterranean → Atlantic</span>
                        {t(defaultLang, 'home.spanishDir')}
            <span class="text-xs font-body bg-stone-700/50 text-stone-300 px-3 py-1 rounded-full">~500km</span>
          </div>
        </div>

        <!-- The Finish -->
        <div class="group relative bg-stone-800/50 rounded-2xl p-8 lg:p-12 border border-stone-700/50 hover:border-amber-500/30 transition-all duration-500">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-amber-500 to-transparent rounded-t-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <span class="text-amber-500/60 font-display text-6xl lg:text-8xl font-bold absolute top-4 right-6 opacity-20">03</span>
          <h3 class="font-display text-2xl lg:text-3xl font-bold text-stone-100 relative" data-i18n="home.frenchTitle">The Finish</h3>
                    {t(defaultLang, 'home.frenchTitle')}
          <p class="text-stone-400 mt-4 leading-relaxed font-body relative" data-i18n="home.frenchDesc">
            {t(defaultLang, 'home.frenchDesc')}
                      {t(defaultLang, 'home.frenchDir')}
          </p>
          <div class="mt-6 flex gap-4 relative">
            <span class="text-xs font-body bg-stone-700/50 text-stone-300 px-3 py-1 rounded-full" data-i18n="home.frenchDir">Atlantic → Mediterranean</span>
            <span class="text-xs font-body bg-stone-700/50 text-stone-300 px-3 py-1 rounded-full">~500km</span>
          </div>
        </div>

        <!-- The Homecoming -->
        <div class="group relative bg-stone-800/50 rounded-2xl p-8 lg:p-12 border border-stone-700/50 hover:border-amber-500/30 transition-all duration-500">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-amber-500 to-transparent rounded-t-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <span class="text-amber-500/60 font-display text-6xl lg:text-8xl font-bold absolute top-4 right-6 opacity-20">04</span>
          <h3 class="font-display text-2xl lg:text-3xl font-bold text-stone-100 relative" data-i18n="home.spanishTitle">The Homecoming</h3>
                    {t(defaultLang, 'home.spanishTitle')}
          <p class="text-stone-400 mt-4 leading-relaxed font-body relative" data-i18n="home.spanishDesc">
            {t(defaultLang, 'home.spanishDesc')}
                      {t(defaultLang, 'home.spanishDir')}
          </p>
          <div class="mt-6 flex gap-4 relative">
            <span class="text-xs font-body bg-stone-700/50 text-stone-300 px-3 py-1 rounded-full" data-i18n="home.spanishDir">Mediterranean → Atlantic</span>
            <span class="text-xs font-body bg-stone-700/50 text-stone-300 px-3 py-1 rounded-full">~500km</span>
          </div>
        </div>

      </div>


      
      <div class="text-center mt-12">
        <a href="/the-challenge" class="inline-flex items-center gap-2 text-amber-400 font-body hover:text-amber-300 transition-colors group">
          <span data-i18n="home.fullDetails">{t(defaultLang, 'home.fullDetails')}</span>
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ ABOUT GBS ═══ -->
  <section class="bg-stone-950 relative">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-40">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7 order-2 lg:order-1">
          <!-- ═══ GBS Explainer Card ═══ -->
          <div class="bg-stone-900 rounded-3xl p-8 lg:p-12 border border-stone-800">
            <h3 class="font-display text-2xl lg:text-3xl font-bold text-stone-100" data-i18n="home.gbsCardTitle">What is Guillain-Barré Syndrome?</h3>
                        {t(defaultLang, 'home.gbsCardTitle')}
            <p class="text-stone-400 mt-6 leading-relaxed font-body" data-i18n="home.gbsCardDesc">
              {t(defaultLang, 'home.gbsCardDesc')}
            </p>
            <div class="mt-8 grid sm:grid-cols-3 gap-4">
              <div class="bg-stone-800/50 rounded-xl p-4 text-center">
                <p class="font-display text-2xl font-bold text-amber-400" data-i18n="home.gbsStat1">1-2</p>
                                {t(defaultLang, 'home.gbsStat1')}
                <p class="text-stone-500 text-xs mt-1 font-body" data-i18n="home.gbsStat1Label">per 100,000 affected</p>
                              {t(defaultLang, 'home.gbsStat1Label')}
              </div>
              <div class="bg-stone-800/50 rounded-xl p-4 text-center">
                <p class="font-display text-2xl font-bold text-amber-400" data-i18n="home.gbsStat2">Weeks</p>
                                {t(defaultLang, 'home.gbsStat2')}
                <p class="text-stone-500 text-xs mt-1 font-body" data-i18n="home.gbsStat2Label">to full paralysis</p>
                              {t(defaultLang, 'home.gbsStat2Label')}
              </div>
              <div class="bg-stone-800/50 rounded-xl p-4 text-center">
                <p class="font-display text-2xl font-bold text-amber-400" data-i18n="home.gbsStat3">Months</p>
                                {t(defaultLang, 'home.gbsStat3')}
                <p class="text-stone-500 text-xs mt-1 font-body" data-i18n="home.gbsStat3Label">to years recovery</p>
                              {t(defaultLang, 'home.gbsStat3Label')}
              </div>
            </div>
            <a href="/about-gbs" class="inline-flex items-center gap-2 text-amber-400 font-body text-sm mt-8 hover:text-amber-300 transition-colors group">
              <span data-i18n="home.learnMoreGbs">{t(defaultLang, 'home.learnMoreGbs')}</span>
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <div class="lg:col-span-5 order-1 lg:order-2">
          <span class="text-amber-500 font-body text-xs tracking-[0.3em] uppercase" data-i18n="home.gbsTag">{t(defaultLang, 'home.gbsTag')}</span>
          <h2 class="font-display text-4xl lg:text-5xl font-bold text-stone-100 mt-4 leading-tight" data-i18n="home.gbsTitle1">
            {t(defaultLang, 'home.gbsTitle1')}<br/>{t(defaultLang, 'home.gbsTitle2')}<br/><span class="text-amber-400" data-i18n="home.gbsTitle3">{t(defaultLang, 'home.gbsTitle3')}</span>
          </h2>
          <p class="text-stone-500 mt-6 font-body leading-relaxed" data-i18n="home.gbsSideDesc">{t(defaultLang, 'home.gbsSideDesc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CHARITY ENDORSEMENT ═══ -->
  <section class="bg-stone-900 border-y border-stone-800">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-32">
      <div class="max-w-4xl mx-auto text-center">
        <span class="text-amber-500/60 font-body text-xs tracking-[0.3em] uppercase" data-i18n="home.quoteTag">{t(defaultLang, 'home.quoteTag')}</span>
          {t(defaultLang, 'home.quoteTag')}
        <blockquote class="mt-8">
          <p class="font-display text-2xl lg:text-4xl text-stone-200 leading-relaxed italic" data-i18n="home.quoteText">
            {t(defaultLang, 'home.quoteText')}
          </p>
        </blockquote>
        <div class="mt-8">
          <p class="text-stone-400 font-body text-sm" data-i18n="home.quoteSource">{t(defaultLang, 'home.quoteSource')}</p>
          <p class="text-stone-600 font-body text-xs mt-1" data-i18n="home.quoteRole">{t(defaultLang, 'home.quoteRole')}</p>
        </div>
        <a href="https://www.inflammatoryneuropathies.uk/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-amber-400 font-body text-sm mt-6 hover:text-amber-300 transition-colors" data-i18n="home.discoverWork">
          {t(defaultLang, 'home.discoverWork')}
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ DONATE CTA ═══ -->
  <section class="bg-stone-950 relative overflow-hidden">
    <!-- Amber glow backdrop -->
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="w-[600px] h-[600px] bg-amber-500/5 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-40 text-center">
      <h2 class="font-display text-4xl lg:text-7xl font-bold text-stone-100 leading-tight">
        <span data-i18n="home.donateCta1">{t(defaultLang, 'home.donateCta1')}</span><br/>
        <span class="text-amber-400" data-i18n="home.donateCta2">{t(defaultLang, 'home.donateCta2')}</span>
      </h2>
      <p class="text-stone-400 text-lg mt-6 max-w-xl mx-auto font-body" data-i18n="home.donateCtaDesc">{t(defaultLang, 'home.donateCtaDesc')}</p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/donate" class="inline-flex items-center justify-center gap-2 bg-amber-500 text-stone-950 px-10 py-4 rounded-full font-body font-bold text-lg hover:bg-amber-400 transition-all duration-300" style="animation: pulse-glow 3s ease-in-out infinite;" data-i18n="home.donateNow">{t(defaultLang, 'home.donateNow')}</a>
        <a href="/support-us" class="inline-flex items-center justify-center gap-2 border border-stone-600 text-stone-300 px-10 py-4 rounded-full font-body hover:border-amber-500 hover:text-amber-400 transition-all duration-300" data-i18n="home.otherWaysToHelp">{t(defaultLang, 'home.otherWaysToHelp')}</a>
      </div>

      <!-- ═══ Fundraising progress ═══ -->
      <div class="mt-16 grid sm:grid-cols-2 gap-8 max-w-lg mx-auto">
        <div>
          <p class="text-stone-500 text-xs font-body uppercase tracking-wider" data-i18n="home.ukTarget">{t(defaultLang, 'home.ukTarget')}</p>
