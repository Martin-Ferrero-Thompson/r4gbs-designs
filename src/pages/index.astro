        <span data-i18n="home.donateCta1">{t(defaultLang, 'home.donateCta1')}</span><br/>
        <span class="text-amber-400" data-i18n="home.donateCta2">{t(defaultLang, 'home.donateCta2')}</span>
      </h2>
