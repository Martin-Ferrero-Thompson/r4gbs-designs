---
/**
 * VERSION 1: CINEMATIC NOIR
 * ─────────────────────────
 * Dark, dramatic, full-bleed. Amber accents cut through volcanic blacks.
 * Think: documentary film poster meets luxury sports brand.
 * Typography: Massive Playfair Display headlines, whisper-thin DM Sans body.
 * Motion: Orchestrated page-load reveal with staggered cinematic timing.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Countdown from '../components/Countdown.tsx';
import { t, defaultLang, translations } from '../i18n/index';
---

<BaseLayout title={t(defaultLang, 'home.heroTitleLine1') + ' ' + t(defaultLang, 'home.heroTitleLine2') + ' ' + t(defaultLang, 'home.heroTitleLine3') + ' | Riding4GBS'}>
  <Navigation />

  <!-- ═══ HERO: FULL VIEWPORT CINEMATIC ═══ -->
  <section class="relative min-h-screen flex items-end bg-stone-950 overflow-hidden">
    <!-- Background image layer -->
    <div class="absolute inset-0">
      <img 
        src="/images/background.png" 
        alt="" 
        class="absolute inset-0 w-full h-full object-cover object-center"
      />
      <!-- Dark overlay for text readability -->
      <div class="absolute inset-0 bg-stone-950/75"></div>
      <!-- Gradient overlay for cinematic depth -->
      <div class="absolute inset-0 bg-gradient-to-b from-stone-950/80 via-transparent to-stone-950/90"></div>
      <!-- Animated gradient shimmer -->
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-amber-500/5 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-1/3 right-1/4 w-64 h-64 bg-amber-500/3 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
    </div>

    <div class="relative z-10 max-w-[1400px] mx-auto px-6 lg:px-10 pb-20 lg:pb-32 pt-32 w-full">
      <!-- ═══ Hashtag marker ═══ -->
      <div class="animate-fade-up">
        <span class="inline-block text-amber-500/80 font-body text-xs tracking-[0.35em] uppercase mb-6" data-i18n="home.heroTag">
          {t(defaultLang, 'home.heroTag')}
        </span>
      </div>

      <!-- ═══ Main headline - massive, cinematic ═══ -->
      <h1 class="font-display text-5xl sm:text-7xl lg:text-[8rem] xl:text-[10rem] font-black leading-[0.85] tracking-tight text-stone-100 animate-fade-up stagger-1" data-i18n="home.heroTitle">
        <span data-i18n="home.heroTitleLine1">{t(defaultLang, 'home.heroTitleLine1')}</span><br/>
        <span class="text-amber-400" data-i18n="home.heroTitleLine2">{t(defaultLang, 'home.heroTitleLine2')}</span> <span data-i18n="home.heroTitleLine3">{t(defaultLang, 'home.heroTitleLine3')}</span>
      </h1>

      <!-- ═══ Subheadline ═══ -->
      <div class="mt-8 lg:mt-12 max-w-2xl animate-fade-up stagger-3">
        <p class="text-stone-400 text-lg lg:text-xl leading-relaxed font-body" data-i18n="home.heroSubtitle">
          {t(defaultLang, 'home.heroSubtitle')}
        </p>
      </div>

      <!-- ═══ CTA cluster ═══ -->
      <div class="mt-10 lg:mt-14 flex flex-wrap gap-4 animate-fade-up stagger-4">
        <a href="/the-challenge" class="group inline-flex items-center gap-3 bg-amber-500 text-stone-950 px-8 py-4 rounded-full font-body font-bold text-sm tracking-wide hover:bg-amber-400 transition-all duration-300 hover:gap-4">
          <span data-i18n="home.discoverChallenge">{t(defaultLang, 'home.discoverChallenge')}</span>
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/donate" class="inline-flex items-center gap-2 border border-stone-600 text-stone-300 px-8 py-4 rounded-full font-body text-sm tracking-wide hover:border-amber-500 hover:text-amber-400 transition-all duration-300" data-i18n="home.donateToResearch">
          {t(defaultLang, 'gbsGlobals.donateToResearch')}
        </a>
      </div>

      <!-- ═══ Charity trust strip ═══ -->
      <div class="mt-8 animate-fade-up stagger-4">
        <p class="text-stone-600 font-body text-xs tracking-[0.2em] uppercase mb-3" data-i18n="home.heroTrustLabel">{t(defaultLang, 'home.heroTrustLabel')}</p>
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-8">
          <a href="https://www.inflammatoryneuropathies.uk/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 group">
            <span class="text-lg leading-none">🇬🇧</span>
            <div>
              <p class="text-stone-300 font-body text-sm group-hover:text-amber-400 transition-colors" data-i18n="home.heroTrustUk">{t(defaultLang, 'gbsGlobals.heroTrustUk')}</p>
              <p class="text-stone-600 font-body text-xs" data-i18n="home.heroTrustUkReg">{t(defaultLang, 'home.heroTrustUkReg')}</p>
            </div>
          </a>
          <a href="https://gbs-cidp.org.es/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 group">
            <span class="text-lg leading-none">🇪🇸</span>
            <div>
              <p class="text-stone-300 font-body text-sm group-hover:text-amber-400 transition-colors" data-i18n="home.heroTrustEs">{t(defaultLang, 'gbsGlobals.heroTrustEs')}</p>
              <p class="text-stone-600 font-body text-xs" data-i18n="home.heroTrustEsReg">{t(defaultLang, 'home.heroTrustEsReg')}</p>
            </div>
          </a>
        </div>
      </div>

      <!-- ═══ Countdown ═══ -->
      <div class="mt-12 animate-fade-up stagger-5">
        <p class="text-stone-500 font-body text-xs tracking-[0.3em] uppercase mb-4" data-i18n="countdown.challengeBeginsIn">{t(defaultLang, 'countdown.challengeBeginsIn')}</p>
        <Countdown client:load targetDate="2026-09-27T09:00:00" />
      </div>

      <!-- ═══ Stats ribbon ═══ -->
      <div class="mt-16 lg:mt-24 grid grid-cols-2 lg:grid-cols-4 gap-8 animate-fade-up stagger-6">
        <div class="border-l-2 border-amber-500/40 pl-4">
          <p class="font-display text-3xl lg:text-5xl font-bold text-stone-100" data-i18n="stats.targetDays">{t(defaultLang, 'stats.targetDays')}</p>
          <p class="text-stone-500 text-sm mt-1 font-body" data-i18n="stats.days">{t(defaultLang, 'stats.days')}</p>
        </div>
        <div class="border-l-2 border-amber-500/40 pl-4">
          <p class="font-display text-3xl lg:text-5xl font-bold text-stone-100" data-i18n="stats.targetKilometres">{t(defaultLang, 'stats.targetKilometres')}</p>
          <p class="text-stone-500 text-sm mt-1 font-body" data-i18n="stats.kilometres">{t(defaultLang, 'stats.kilometres')}</p>
        </div>
        <div class="border-l-2 border-amber-500/40 pl-4">
          <p class="font-display text-3xl lg:text-5xl font-bold text-stone-100" data-i18n="stats.targetMetresClimbed">{t(defaultLang, 'stats.targetMetresClimbed')}</p>
          <p class="text-stone-500 text-sm mt-1 font-body" data-i18n="stats.metresOfClimbing">{t(defaultLang, 'stats.metresOfClimbing')}</p>
        </div>
        <div class="border-l-2 border-amber-500/40 pl-4">
          <p class="font-display text-3xl lg:text-5xl font-bold text-stone-100" data-i18n="stats.targetEverestSummits">{t(defaultLang, 'stats.targetEverestSummits')}</p>
          <p class="text-stone-500 text-sm mt-1 font-body" data-i18n="stats.heightOfEverest">{t(defaultLang, 'stats.heightOfEverest')}</p>
        </div>
      </div>
    </div>

  </section>

  <!-- ═══ MISSION STATEMENT ═══ -->
  <section class="bg-stone-950 relative">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-40">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-5">
          <span class="text-amber-500 font-body text-xs tracking-[0.3em] uppercase" data-i18n="home.missionTag">{t(defaultLang, 'home.missionTag')}</span>
          <h2 class="font-display text-4xl lg:text-6xl font-bold text-stone-100 mt-4 leading-tight">
            {t(defaultLang, 'home.missionTitle1')}<br/>{t(defaultLang, 'home.missionTitle2')}
          </h2>
        </div>
        <div class="lg:col-span-7 lg:pt-12">
          <p class="text-stone-400 text-lg lg:text-xl leading-relaxed max-w-2xl font-body" data-i18n="home.missionDesc">{t(defaultLang, 'home.missionDesc')}</p>
          <p class="text-stone-500 text-lg leading-relaxed max-w-2xl mt-6 font-body" data-i18n="home.missionDesc2">{t(defaultLang, 'home.missionDesc2')}</p>
          <a href="/our-story" class="inline-flex items-center gap-2 text-amber-400 font-body text-sm mt-8 hover:text-amber-300 transition-colors group">
            <span data-i18n="home.readFullStory">{t(defaultLang, 'home.readFullStory')}</span>
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ THE CHALLENGE PREVIEW ═══ -->
  <section class="bg-stone-900 relative overflow-hidden">
    <!-- ═══Diagonal amber accent line ═══ -->
    <div class="absolute top-0 right-0 w-1 h-full bg-gradient-to-b from-amber-500/0 via-amber-500/30 to-amber-500/0"></div>

    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-40">
      <div class="text-center mb-16 lg:mb-24">
        <span class="text-amber-500 font-body text-xs tracking-[0.3em] uppercase" data-i18n="home.challengeTag">{t(defaultLang, 'home.challengeTag')}</span>
        <h2 class="font-display text-4xl lg:text-6xl font-bold text-stone-100 mt-4" data-i18n="home.challengeTitle">
          {t(defaultLang, 'home.challengeTitle')}
        </h2>
        <p class="text-stone-400 text-lg mt-6 max-w-2xl mx-auto font-body" data-i18n="home.challengeDesc">
          {t(defaultLang, 'home.challengeDesc')}
        </p>
      </div>

      <!-- ═══ Route cards ═══ -->
      <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
        <!-- 01 The Start -->
        <div class="group relative bg-stone-900 rounded-2xl p-8 lg:p-12 border border-stone-800 hover:border-amber-500/30 transition-all duration-500 flex flex-col">
          <span class="text-amber-500/60 font-display text-6xl lg:text-8xl font-bold absolute top-4 right-6 opacity-20" data-i18n="theChallenge.theStartNum">{t(defaultLang, 'theChallenge.theStartNum')}</span>
          <h3 class="font-display text-2xl lg:text-3xl font-bold text-stone-100 mt-2" data-i18n="theChallenge.theStartTitle">{t(defaultLang, 'theChallenge.theStartTitle')}</h3>
          <p class="text-stone-400 mt-4 leading-relaxed font-body" data-i18n="theChallenge.theStartDesc">{t(defaultLang, 'theChallenge.theStartDesc')}</p>
          <div class="mt-6 space-y-2">
            <div class="flex justify-between text-xs font-body">
              <span class="text-stone-500" data-i18n="theChallenge.direction">{t(defaultLang, 'theChallenge.direction')}</span>
              <span class="text-stone-300" data-i18n="theChallenge.theStartDirection">{t(defaultLang, 'theChallenge.theStartDirection')}</span>
            </div>
            <div class="flex justify-between text-xs font-body">
              <span class="text-stone-500" data-i18n="theChallenge.distance">{t(defaultLang, 'theChallenge.distance')}</span>
              <span class="text-stone-300" data-i18n="theChallenge.theStartDistance">{t(defaultLang, 'theChallenge.theStartDistance')}</span>
            </div>
            <div class="flex justify-between text-xs font-body">
              <span class="text-stone-500" data-i18n="theChallenge.elevationGain">{t(defaultLang, 'theChallenge.elevationGain')}</span>
              <span class="text-stone-300" data-i18n="theChallenge.theStartElevationGain">{t(defaultLang, 'theChallenge.theStartElevationGain')}</span>
            </div>
            <div class="flex justify-between text-xs font-body">
              <span class="text-stone-500" data-i18n="theChallenge.terrain">{t(defaultLang, 'theChallenge.terrain')}</span>
              <span class="text-stone-300" data-i18n="theChallenge.theStartTerrain">{t(defaultLang, 'theChallenge.theStartTerrain')}</span>
            </div>
          </div>
        </div>

        <!-- 02 The Climbing -->
        <div class="group relative bg-stone-900 rounded-2xl p-8 lg:p-12 border border-stone-800 hover:border-amber-500/30 transition-all duration-500 flex flex-col">
          <span class="text-amber-500/60 font-display text-6xl lg:text-8xl font-bold absolute top-4 right-6 opacity-20" data-i18n="theChallenge.theClimbingNum">{t(defaultLang, 'theChallenge.theClimbingNum')}</span>
          <h3 class="font-display text-2xl lg:text-3xl font-bold text-stone-100 mt-2" data-i18n="theChallenge.theClimbingTitle">{t(defaultLang, 'theChallenge.theClimbingTitle')}</h3>
          <p class="text-stone-400 mt-4 leading-relaxed font-body" data-i18n="theChallenge.theClimbingDesc">{t(defaultLang, 'theChallenge.theClimbingDesc')}</p>
          <div class="mt-6 space-y-2">
            <div class="flex justify-between text-xs font-body">
              <span class="text-stone-500" data-i18n="theChallenge.direction">{t(defaultLang, 'theChallenge.direction')}</span>
              <span class="text-stone-300" data-i18n="theChallenge.theClimbingDirection">{t(defaultLang, 'theChallenge.theClimbingDirection')}</span>
            </div>
            <div class="flex justify-between text-xs font-body">
              <span class="text-stone-500" data-i18n="theChallenge.distance">{t(defaultLang, 'theChallenge.distance')}</span>
              <span class="text-stone-300" data-i18n="theChallenge.theClimbingDistance">{t(defaultLang, 'theChallenge.theClimbingDistance')}</span>
            </div>
            <div class="flex justify-between text-xs font-body">
              <span class="text-stone-500" data-i18n="theChallenge.elevationGain">{t(defaultLang, 'theChallenge.elevationGain')}</span>
              <span class="text-stone-300" data-i18n="theChallenge.theClimbingElevationGain">{t(defaultLang, 'theChallenge.theClimbingElevationGain')}</span>
            </div>
            <div class="flex justify-between text-xs font-body">
              <span class="text-stone-500" data-i18n="theChallenge.terrain">{t(defaultLang, 'theChallenge.terrain')}</span>
              <span class="text-stone-300" data-i18n="theChallenge.theClimbingTerrain">{t(defaultLang, 'theChallenge.theClimbingTerrain')}</span>
            </div>
          </div>
        </div>

        <!-- 03 The Finish -->
        <div class="group relative bg-stone-900 rounded-2xl p-8 lg:p-12 border border-stone-800 hover:border-amber-500/30 transition-all duration-500 flex flex-col">
          <span class="text-amber-500/60 font-display text-6xl lg:text-8xl font-bold absolute top-4 right-6 opacity-20" data-i18n="theChallenge.theFinishNum">{t(defaultLang, 'theChallenge.theFinishNum')}</span>
          <h3 class="font-display text-2xl lg:text-3xl font-bold text-stone-100 mt-2" data-i18n="theChallenge.theFinishTitle">{t(defaultLang, 'theChallenge.theFinishTitle')}</h3>
          <p class="text-stone-400 mt-4 leading-relaxed font-body" data-i18n="theChallenge.theFinishDesc">{t(defaultLang, 'theChallenge.theFinishDesc')}</p>
          <div class="mt-6 space-y-2">
            <div class="flex justify-between text-xs font-body">
              <span class="text-stone-500" data-i18n="theChallenge.direction">{t(defaultLang, 'theChallenge.direction')}</span>
              <span class="text-stone-300" data-i18n="theChallenge.theFinishDirection">{t(defaultLang, 'theChallenge.theFinishDirection')}</span>
            </div>
            <div class="flex justify-between text-xs font-body">
              <span class="text-stone-500" data-i18n="theChallenge.distance">{t(defaultLang, 'theChallenge.distance')}</span>
              <span class="text-stone-300" data-i18n="theChallenge.theFinishDistance">{t(defaultLang, 'theChallenge.theFinishDistance')}</span>
            </div>
            <div class="flex justify-between text-xs font-body">
              <span class="text-stone-500" data-i18n="theChallenge.elevationGain">{t(defaultLang, 'theChallenge.elevationGain')}</span>
              <span class="text-stone-300" data-i18n="theChallenge.theFinishElevationGain">{t(defaultLang, 'theChallenge.theFinishElevationGain')}</span>
            </div>
            <div class="flex justify-between text-xs font-body">
              <span class="text-stone-500" data-i18n="theChallenge.terrain">{t(defaultLang, 'theChallenge.terrain')}</span>
              <span class="text-stone-300" data-i18n="theChallenge.theFinishTerrain">{t(defaultLang, 'theChallenge.theFinishTerrain')}</span>
            </div>
          </div>
        </div>

        <!-- 04 The Homecoming -->
        <div class="group relative bg-stone-900 rounded-2xl p-8 lg:p-12 border border-stone-800 hover:border-amber-500/30 transition-all duration-500 flex flex-col">
          <span class="text-amber-500/60 font-display text-6xl lg:text-8xl font-bold absolute top-4 right-6 opacity-20" data-i18n="theChallenge.theHomecomingNum">{t(defaultLang, 'theChallenge.theHomecomingNum')}</span>
          <h3 class="font-display text-2xl lg:text-3xl font-bold text-stone-100 mt-2" data-i18n="theChallenge.theHomecomingTitle">{t(defaultLang, 'theChallenge.theHomecomingTitle')}</h3>
          <p class="text-stone-400 mt-4 leading-relaxed font-body" data-i18n="theChallenge.theHomecomingDesc">{t(defaultLang, 'theChallenge.theHomecomingDesc')}</p>
          <div class="mt-6 space-y-2">
            <div class="flex justify-between text-xs font-body">
              <span class="text-stone-500" data-i18n="theChallenge.direction">{t(defaultLang, 'theChallenge.direction')}</span>
              <span class="text-stone-300" data-i18n="theChallenge.theHomecomingDirection">{t(defaultLang, 'theChallenge.theHomecomingDirection')}</span>
            </div>
            <div class="flex justify-between text-xs font-body">
              <span class="text-stone-500" data-i18n="theChallenge.distance">{t(defaultLang, 'theChallenge.distance')}</span>
              <span class="text-stone-300" data-i18n="theChallenge.theHomecomingDistance">{t(defaultLang, 'theChallenge.theHomecomingDistance')}</span>
            </div>
            <div class="flex justify-between text-xs font-body">
              <span class="text-stone-500" data-i18n="theChallenge.elevationGain">{t(defaultLang, 'theChallenge.elevationGain')}</span>
              <span class="text-stone-300" data-i18n="theChallenge.theHomecomingElevationGain">{t(defaultLang, 'theChallenge.theHomecomingElevationGain')}</span>
            </div>
            <div class="flex justify-between text-xs font-body">
              <span class="text-stone-500" data-i18n="theChallenge.terrain">{t(defaultLang, 'theChallenge.terrain')}</span>
              <span class="text-stone-300" data-i18n="theChallenge.theHomecomingTerrain">{t(defaultLang, 'theChallenge.theHomecomingTerrain')}</span>
            </div>
          </div>
        </div>

      </div>


      
      <div class="text-center mt-12">
        <a href="/the-challenge" class="inline-flex items-center gap-2 text-amber-400 font-body hover:text-amber-300 transition-colors group">
          <span data-i18n="home.fullDetails">{t(defaultLang, 'home.fullDetails')}</span>
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ ABOUT GBS ═══ -->
  <section class="bg-stone-950 relative">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-40">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <!-- Left: Mission Tag & Headline -->
        <div class="lg:col-span-5 flex flex-col">
          <span class="text-amber-500 font-body text-xs tracking-[0.3em] uppercase mb-6 block" data-i18n="home.gbsTag">{t(defaultLang, 'home.gbsTag')}</span>
          <h2 class="font-display text-5xl lg:text-7xl font-bold text-stone-100 leading-tight">
            {t(defaultLang, 'home.gbsTitle1')}<br/>{t(defaultLang, 'home.gbsTitle2')}<br/><span class="text-amber-400" data-i18n="home.gbsTitle3">{t(defaultLang, 'home.gbsTitle3')}</span>
          </h2>
        </div>
        <!-- Right: Description & Link -->
        <div class="lg:col-span-7 flex flex-col">
          <div>
            <p class="text-stone-300 text-lg lg:text-xl leading-relaxed font-body mb-6" data-i18n="home.gbsSideDesc">{t(defaultLang, 'home.gbsSideDesc')}</p>
            <p class="text-stone-500 text-lg leading-relaxed font-body mb-2" data-i18n="home.gbsSideDesc2">{t(defaultLang, 'home.gbsSideDesc2')}</p>
            <ol class="text-stone-500 text-lg leading-relaxed font-body mb-8 list-decimal list-inside pl-2" data-i18n-list="home.gbsSideDesc2List">
              {translations[defaultLang].home.gbsSideDesc2List.map((item: string) => <li>{item}</li>)}
            </ol>
            <!-- GBS Explainer Card -->
            <div class="bg-stone-900 rounded-3xl p-8 lg:p-12 border border-stone-800 mb-8">
              <h3 class="font-display text-3xl lg:text-4xl font-bold text-stone-100 mb-6" data-i18n="home.gbsCardTitle">{t(defaultLang, 'home.gbsCardTitle')}</h3>
              <p class="text-stone-400 text-lg leading-relaxed font-body mb-8" data-i18n="home.gbsCardDesc">{t(defaultLang, 'home.gbsCardDesc')}</p>
              <div class="grid sm:grid-cols-3 gap-4 mb-8">
                <div class="bg-stone-800/50 rounded-xl p-6 text-center">
                  <p class="font-display text-2xl font-bold text-amber-400 mb-1" data-i18n="home.gbsStat1">{t(defaultLang, 'home.gbsStat1')}</p>
                  <p class="text-stone-500 text-xs font-body mb-1" data-i18n="home.gbsStat1Label">{t(defaultLang, 'home.gbsStat1Label')}</p>
                </div>
                <div class="bg-stone-800/50 rounded-xl p-6 text-center">
                  <p class="font-display text-2xl font-bold text-amber-400 mb-1" data-i18n="home.gbsStat2">{t(defaultLang, 'home.gbsStat2')}</p>
                  <p class="text-stone-500 text-xs font-body mb-1" data-i18n="home.gbsStat2Label">{t(defaultLang, 'home.gbsStat2Label')}</p>
                </div>
                <div class="bg-stone-800/50 rounded-xl p-6 text-center">
                  <p class="font-display text-2xl font-bold text-amber-400 mb-1" data-i18n="home.gbsStat3">{t(defaultLang, 'home.gbsStat3')}</p>
                  <p class="text-stone-500 text-xs font-body mb-1" data-i18n="home.gbsStat3Label">{t(defaultLang, 'home.gbsStat3Label')}</p>
                </div>
              </div>
            </div>
            <a href="/about-gbs" class="inline-flex items-center gap-2 text-amber-400 font-body text-base mt-2 hover:text-amber-300 transition-colors group font-semibold">
