        <a href="https://www.inflammatoryneuropathies.uk/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-amber-400 font-body text-sm mt-6 hover:text-amber-300 transition-colors" data-i18n="home.discoverWork">
