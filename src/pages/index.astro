      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/donate" class="inline-flex items-center justify-center gap-2 bg-amber-500 text-stone-950 px-10 py-4 rounded-full font-body font-bold text-lg hover:bg-amber-400 transition-all duration-300" style="animation: pulse-glow 3s ease-in-out infinite;" data-i18n="home.donateNow">{t(defaultLang, 'gbsGlobals.donateNow')}</a>
        <a href="/support-us" class="inline-flex items-center justify-center gap-2 border border-stone-600 text-stone-300 px-10 py-4 rounded-full font-body hover:border-amber-500 hover:text-amber-400 transition-all duration-300" data-i18n="home.otherWaysToHelp">{t(defaultLang, 'home.otherWaysToHelp')}</a>
