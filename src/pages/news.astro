---
import PageLayout from '../layouts/PageLayout.astro';
import { t, defaultLang } from '../i18n';
---

<PageLayout
  title={t(defaultLang, 'news.pageTitle')}
  heroTitle={t(defaultLang, 'news.heroTitle')}
  heroSubtitle={t(defaultLang, 'news.heroSubtitle')}
  heroTitleKey="news.heroTitle"
  heroSubtitleKey="news.heroSubtitle"
>
  <section>
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-32">
      <div class="max-w-3xl mx-auto">

        <!-- Placeholder news items -->
        <div class="space-y-8">
          <article class="bg-stone-900 rounded-2xl p-8 border border-stone-800 hover:border-stone-700 transition-colors">
            <span class="text-amber-500/60 font-body text-xs uppercase tracking-wider" data-i18n="news.announcementTag">{t(defaultLang, 'news.announcementTag')}</span>
            <h2 class="font-display text-2xl font-bold text-stone-100 mt-2" data-i18n="news.article1Title">{t(defaultLang, 'news.article1Title')}</h2>
            <p class="text-stone-400 font-body mt-4 leading-relaxed" data-i18n="news.article1Desc">{t(defaultLang, 'news.article1Desc')}</p>
            <div class="mt-6 flex flex-wrap items-center gap-4">
              <span class="text-stone-600 text-sm font-body" data-i18n="news.article1Date">{t(defaultLang, 'news.article1Date')}</span>
              <a href="/the-challenge" class="text-amber-400 text-sm font-body hover:text-amber-300 transition-colors" data-i18n="news.readMore">{t(defaultLang, 'news.readMore')}</a>
            </div>
          </article>

          <article class="bg-stone-900 rounded-2xl p-8 border border-stone-800 hover:border-stone-700 transition-colors">
            <span class="text-amber-500/60 font-body text-xs uppercase tracking-wider" data-i18n="news.partnershipTag">{t(defaultLang, 'news.partnershipTag')}</span>
            <h2 class="font-display text-2xl font-bold text-stone-100 mt-2" data-i18n="news.article2Title">{t(defaultLang, 'news.article2Title')}</h2>
            <p class="text-stone-400 font-body mt-4 leading-relaxed" data-i18n="news.article2Desc">{t(defaultLang, 'news.article2Desc')}</p>
            <div class="mt-6 flex flex-wrap items-center gap-4">
              <span class="text-stone-600 text-sm font-body" data-i18n="news.article2Date">{t(defaultLang, 'news.article2Date')}</span>
              <span class="text-amber-400 text-sm font-body" data-i18n="news.readMore">{t(defaultLang, 'news.readMore')}</span>
            </div>
          </article>
        </div>

        <!-- Coming soon notice -->
        <div class="mt-12 text-center">
          <p class="text-stone-600 font-body text-sm" data-i18n="news.moreNews">{t(defaultLang, 'news.moreNews')}</p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
