---
import PageLayout from '../layouts/PageLayout.astro';
import { t, defaultLang } from '../i18n/index';
---

<PageLayout
  title={t(defaultLang, 'ourStory.pageTitle')}
  heroTitle={t(defaultLang, 'ourStory.heroTitle')}
  heroSubtitle={t(defaultLang, 'ourStory.heroSubtitle')}
  heroTitleKey="ourStory.heroTitle"
  heroSubtitleKey="ourStory.heroSubtitle"
>
  <section>
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-32">
      <div class="max-w-3xl mx-auto">

        <!-- Chapter 1 The Rider Before-->
        <div class="mb-20">
          <span class="text-amber-500 font-body text-xs tracking-[0.3em] uppercase" data-i18n="ourStory.ch1Tag">{t(defaultLang, 'ourStory.ch1Tag')}</span>
          <h2 class="font-display text-3xl lg:text-5xl font-bold text-stone-100 mt-3 leading-tight" data-i18n="ourStory.ch1Title">{t(defaultLang, 'ourStory.ch1Title')}</h2>
          <div class="mt-8 space-y-6">
            <p class="text-stone-400 text-lg leading-relaxed font-body" data-i18n="ourStory.ch1p1">{t(defaultLang, 'ourStory.ch1p1')}</p>
          </div>
        </div>

        <!-- Divider -->
        <div class="flex items-center gap-6 mb-20">
          <div class="flex-1 h-px bg-stone-800"></div>
          <div class="w-3 h-3 bg-amber-500 rotate-45"></div>
          <div class="flex-1 h-px bg-stone-800"></div>
        </div>

        <!-- Chapter 2 The Day the World Stopped -->
        <div class="mb-20">
          <span class="text-amber-500 font-body text-xs tracking-[0.3em] uppercase" data-i18n="ourStory.ch2Tag">{t(defaultLang, 'ourStory.ch2Tag')}</span>
          <h2 class="font-display text-3xl lg:text-5xl font-bold text-stone-100 mt-3 leading-tight" data-i18n="ourStory.ch2Title">{t(defaultLang, 'ourStory.ch2Title')}</h2>
          <div class="mt-8 space-y-6">
            <p class="text-stone-400 text-lg leading-relaxed font-body" data-i18n="ourStory.ch2p1">{t(defaultLang, 'ourStory.ch2p1')}</p>
          </div>
        </div>

        <!-- Divider -->
        <div class="flex items-center gap-6 mb-20">
          <div class="flex-1 h-px bg-stone-800"></div>
          <div class="w-3 h-3 bg-amber-500 rotate-45"></div>
          <div class="flex-1 h-px bg-stone-800"></div>
        </div>

        <!-- Chapter 3 -->
        <div class="mb-20">
          <span class="text-amber-500 font-body text-xs tracking-[0.3em] uppercase" data-i18n="ourStory.ch3Tag">{t(defaultLang, 'ourStory.ch3Tag')}</span>
          <h2 class="font-display text-3xl lg:text-5xl font-bold text-stone-100 mt-3 leading-tight" data-i18n="ourStory.ch3Title">{t(defaultLang, 'ourStory.ch3Title')}</h2>
          <div class="mt-8 space-y-6">
            <p class="text-stone-400 text-lg leading-relaxed font-body" data-i18n="ourStory.ch3p1">{t(defaultLang, 'ourStory.ch3p1')}</p>
          </div>
        </div>

        <!-- Divider -->
        <div class="flex items-center gap-6 mb-20">
          <div class="flex-1 h-px bg-stone-800"></div>
          <div class="w-3 h-3 bg-amber-500 rotate-45"></div>
          <div class="flex-1 h-px bg-stone-800"></div>
        </div>        

        <!-- Chapter 4 -->
        <div class="mb-20">
          <span class="text-amber-500 font-body text-xs tracking-[0.3em] uppercase" data-i18n="ourStory.ch4Tag">{t(defaultLang, 'ourStory.ch4Tag')}</span>
          <h2 class="font-display text-3xl lg:text-5xl font-bold text-stone-100 mt-3 leading-tight" data-i18n="ourStory.ch4Title">{t(defaultLang, 'ourStory.ch4Title')}</h2>
          <div class="mt-8 space-y-6">
            <p class="text-stone-400 text-lg leading-relaxed font-body" data-i18n="ourStory.ch4p1">{t(defaultLang, 'ourStory.ch4p1')}</p>
          </div>
        </div>

        <!-- Divider -->
        <div class="flex items-center gap-6 mb-20">
          <div class="flex-1 h-px bg-stone-800"></div>
          <div class="w-3 h-3 bg-amber-500 rotate-45"></div>
          <div class="flex-1 h-px bg-stone-800"></div>
        </div>        

        <!-- CTA -->
        <div class="text-center bg-stone-900 rounded-2xl p-10 lg:p-14 border border-stone-800">
          <h3 class="font-display text-2xl lg:text-3xl font-bold text-stone-100" data-i18n="ourStory.ctaTitle">{t(defaultLang, 'ourStory.ctaTitle')}</h3>
          <p class="text-stone-400 font-body mt-4 max-w-lg mx-auto" data-i18n="ourStory.ctaDesc">{t(defaultLang, 'ourStory.ctaDesc')}</p>
          <div class="mt-8 flex flex-wrap gap-4 justify-center">
            <a href="/the-challenge" class="inline-flex items-center gap-2 bg-amber-500 text-stone-950 px-8 py-3 rounded-full font-body font-bold text-sm hover:bg-amber-400 transition-colors" data-i18n="ourStory.ctaChallenge">{t(defaultLang, 'ourStory.ctaChallenge')}</a>
            <a href="/donate" class="inline-flex items-center gap-2 border border-stone-600 text-stone-300 px-8 py-3 rounded-full font-body text-sm hover:border-amber-500 hover:text-amber-400 transition-colors" data-i18n="ourStory.ctaDonate">{t(defaultLang, 'ourStory.ctaDonate')}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
