---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Our Story"
  heroTitle="The Slow Road Back"
  heroSubtitle="Hi, I'm Martin. In 2021, Guillain-Barré Syndrome changed my life, but it didn't define it. This is my story so far..."
  heroTitleKey="ourStory.heroTitle"
  heroSubtitleKey="ourStory.heroSubtitle"
>
  <section>
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-32">
      <div class="max-w-3xl mx-auto">

        <!-- Chapter 1 -->
        <div class="mb-20">
          <span class="text-amber-500 font-body text-xs tracking-[0.3em] uppercase" data-i18n="ourStory.ch1Tag"></span>
          <h2 class="font-display text-3xl lg:text-5xl font-bold text-stone-100 mt-3 leading-tight" data-i18n="ourStory.ch1Title"></h2>
          <div class="mt-8 space-y-6">
            <p class="text-stone-400 text-lg leading-relaxed font-body" data-i18n="ourStory.ch1p1"></p>
            <p class="text-stone-400 text-lg leading-relaxed font-body" data-i18n="ourStory.ch1p2"></p>
            <p class="text-stone-400 text-lg leading-relaxed font-body" data-i18n="ourStory.ch1p3"></p>
          </div>
        </div>

        <!-- Divider -->
        <div class="flex items-center gap-6 mb-20">
          <div class="flex-1 h-px bg-stone-800"></div>
          <div class="w-3 h-3 bg-amber-500 rotate-45"></div>
          <div class="flex-1 h-px bg-stone-800"></div>
        </div>

        <!-- Chapter 2 -->
        <div class="mb-20">
          <span class="text-amber-500 font-body text-xs tracking-[0.3em] uppercase" data-i18n="ourStory.ch2Tag"></span>
          <h2 class="font-display text-3xl lg:text-5xl font-bold text-stone-100 mt-3 leading-tight" data-i18n="ourStory.ch2Title"></h2>
          <div class="mt-8 space-y-6">
            <p class="text-stone-400 text-lg leading-relaxed font-body" data-i18n="ourStory.ch2p1"></p>
            <p class="text-stone-400 text-lg leading-relaxed font-body" data-i18n="ourStory.ch2p2"></p>
          </div>
        </div>

        <!-- Highlight quote -->
        <div class="bg-stone-900 rounded-2xl p-8 lg:p-12 border border-stone-800 mb-20">
          <p class="font-display text-2xl lg:text-3xl text-amber-400 leading-relaxed italic" data-i18n="ourStory.quoteText"></p>
          <p class="text-stone-500 text-sm mt-4 font-body" data-i18n="ourStory.quoteDesc"></p>
        </div>

        <!-- Chapter 3 -->
        <div class="mb-20">
          <span class="text-amber-500 font-body text-xs tracking-[0.3em] uppercase" data-i18n="ourStory.ch3Tag"></span>
          <h2 class="font-display text-3xl lg:text-5xl font-bold text-stone-100 mt-3 leading-tight" data-i18n="ourStory.ch3Title"></h2>
          <div class="mt-8 space-y-6">
            <p class="text-stone-400 text-lg leading-relaxed font-body" data-i18n="ourStory.ch3p1"></p>
            <p class="text-stone-400 text-lg leading-relaxed font-body" data-i18n="ourStory.ch3p2"></p>
            <p class="text-stone-400 text-lg leading-relaxed font-body" data-i18n="ourStory.ch3p3"></p>
          </div>
        </div>

        <!-- CTA -->
        <div class="text-center bg-stone-900 rounded-2xl p-10 lg:p-14 border border-stone-800">
          <h3 class="font-display text-2xl lg:text-3xl font-bold text-stone-100" data-i18n="ourStory.ctaTitle"></h3>
          <p class="text-stone-400 font-body mt-4 max-w-lg mx-auto" data-i18n="ourStory.ctaDesc"></p>
          <div class="mt-8 flex flex-wrap gap-4 justify-center">
            <a href="/the-challenge" class="inline-flex items-center gap-2 bg-amber-500 text-stone-950 px-8 py-3 rounded-full font-body font-bold text-sm hover:bg-amber-400 transition-colors" data-i18n="ourStory.ctaChallenge"></a>
            <a href="/donate" class="inline-flex items-center gap-2 border border-stone-600 text-stone-300 px-8 py-3 rounded-full font-body text-sm hover:border-amber-500 hover:text-amber-400 transition-colors" data-i18n="ourStory.ctaDonate"></a>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
