---
import PageLayout from '../layouts/PageLayout.astro';
import { t, defaultLang } from '../i18n/index';
---

<PageLayout
  title="Support Us"
  heroTitle="Be Part of the Effort"
  heroSubtitle="A self-supported ride across the Pyrenees is a huge logistical challenge. This page is for those who wish to contribute directly to supporting the ride itself."
  heroTitleKey="supportUs.heroTitle"
  heroSubtitleKey="supportUs.heroSubtitle"
>
  <section>
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-32">
      <div class="grid lg:grid-cols-12 gap-16">
        <div class="lg:col-span-7">
          <!-- Help Keep the Wheels Turning -->
          <div class="mb-16">
            <h2 class="font-display text-3xl lg:text-4xl font-bold text-stone-100" data-i18n="supportUs.wheelsTitle">{t(defaultLang, 'gbsGlobals.supportUs')}</h2>
            <p class="text-stone-400 text-lg leading-relaxed font-body mt-6" data-i18n="supportUs.wheelsDesc1">{t(defaultLang, 'supportUs.wheelsDesc1')}</p>
            <p class="text-stone-500 text-lg leading-relaxed font-body mt-4" data-i18n="supportUs.wheelsDesc2">{t(defaultLang, 'supportUs.wheelsDesc2')}</p>
            <a href="https://ko-fi.com/riding4gbs" target="_blank" rel="noopener noreferrer" data-track-event="Ko-fi Click" data-track-props='{"location":"support-us"}' class="inline-flex items-center gap-2 bg-amber-500 text-stone-950 px-8 py-4 rounded-full font-body font-bold mt-8 hover:bg-amber-400 transition-colors" data-i18n="supportUs.supportOnKofi">{t(defaultLang, 'supportUs.supportOnKofi')}</a>
          </div>

          <!-- Ways to Help -->
          <div>
            <h2 class="font-display text-3xl font-bold text-stone-100 mb-8" data-i18n="supportUs.otherWaysTitle">{t(defaultLang, 'supportUs.otherWaysTitle')}</h2>
            <div class="space-y-4">
              <div class="bg-stone-900 rounded-xl p-6 border border-stone-800">
                <h3 class="font-display text-lg font-bold text-amber-400" data-i18n="supportUs.shareTitle">{t(defaultLang, 'supportUs.shareTitle')}</h3>
                <p class="text-stone-400 text-sm mt-2 font-body" data-i18n="supportUs.shareDesc">{t(defaultLang, 'supportUs.shareDesc')}</p>
              </div>
              <div class="bg-stone-900 rounded-xl p-6 border border-stone-800">
                <h3 class="font-display text-lg font-bold text-amber-400" data-i18n="supportUs.rideTitle">{t(defaultLang, 'supportUs.rideTitle')}</h3>
                <p class="text-stone-400 text-sm mt-2 font-body" data-i18n="supportUs.rideDesc">{t(defaultLang, 'supportUs.rideDesc')}</p>
              </div>
              <div class="bg-stone-900 rounded-xl p-6 border border-stone-800">
                <h3 class="font-display text-lg font-bold text-amber-400" data-i18n="supportUs.partnerTitle">{t(defaultLang, 'supportUs.partnerTitle')}</h3>
                <p class="text-stone-400 text-sm mt-2 font-body">
                  <span data-i18n="supportUs.partnerDesc">{t(defaultLang, 'supportUs.partnerDesc')}</span> <span class="text-amber-400" data-i18n="supportUs.partnerLink">{t(defaultLang, 'supportUs.partnerLink')}</span>
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Support Crew sidebar -->
        <div class="lg:col-span-5">
          <div class="lg:sticky lg:top-28">
            <div class="bg-stone-900 rounded-2xl p-8 border border-stone-800">
              <h3 class="font-display text-xl font-bold text-stone-100 mb-6" data-i18n="supportUs.crewTitle">{t(defaultLang, 'supportUs.crewTitle')}</h3>
              <p class="text-stone-500 text-sm font-body mb-6" data-i18n="supportUs.crewDesc">{t(defaultLang, 'supportUs.crewDesc')}</p>

              <div class="space-y-4">
                <div class="flex items-center gap-4">
                  <div class="w-12 h-12 bg-amber-500/10 rounded-full flex items-center justify-center">
                    <span class="text-amber-500 font-display font-bold">MT</span>
                  </div>
                  <div>
                    <p class="text-stone-200 font-body font-medium text-sm">Martin Thompson</p>
                    <p class="text-stone-600 text-xs font-body">España</p>
                  </div>
                </div>
                <div class="flex items-center gap-4">
                  <div class="w-12 h-12 bg-amber-500/10 rounded-full flex items-center justify-center">
                    <span class="text-amber-500 font-display font-bold">EF</span>
                  </div>
                  <div>
                    <p class="text-stone-200 font-body font-medium text-sm">Edurne Ferrero Aguirre</p>
                    <p class="text-stone-600 text-xs font-body">España</p>
                  </div>
                </div>
                <div class="flex items-center gap-4">
                  <div class="w-12 h-12 bg-amber-500/10 rounded-full flex items-center justify-center">
                    <span class="text-amber-500 font-display font-bold">AD</span>
                  </div>
                  <div>
                    <p class="text-stone-200 font-body font-medium text-sm">Andrew Deeley</p>
                    <p class="text-stone-600 text-xs font-body">United Kingdom</p>
                  </div>
                </div>
              </div>

              <a href="https://ko-fi.com/riding4gbs" target="_blank" rel="noopener noreferrer" data-track-event="Ko-fi Click" data-track-props='{"location":"support-us-sidebar"}' class="block text-center mt-8 bg-amber-500 text-stone-950 px-6 py-3 rounded-full font-body font-bold text-sm hover:bg-amber-400 transition-colors" data-i18n="supportUs.joinCrew">{t(defaultLang, 'supportUs.joinCrew')}</a>
            </div>

            <!-- Charity reminder -->
            <div class="mt-6 bg-amber-500/10 rounded-2xl p-6 border border-amber-500/20">
              <p class="text-amber-400 font-display text-sm font-bold" data-i18n="supportUs.donateReminder">{t(defaultLang, 'supportUs.donateReminder')}</p>
              <p class="text-stone-400 text-sm font-body mt-2" data-i18n="supportUs.donateReminderDesc">{t(defaultLang, 'supportUs.donateReminderDesc')}</p>
              <a href="/donate" class="text-amber-400 text-sm font-body mt-2 inline-block hover:text-amber-300 transition-colors" data-i18n="supportUs.goToDonate">{t(defaultLang, 'supportUs.goToDonate')}</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
