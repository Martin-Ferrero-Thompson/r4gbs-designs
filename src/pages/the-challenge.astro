---
import PageLayout from "../layouts/PageLayout.astro";
import { t, defaultLang } from "../i18n";
---

<PageLayout
  title={t(defaultLang, "gbsGlobals.challenge")}
  heroTitle={t(defaultLang, "theChallenge.heroTitle")}
  heroSubtitle={t(defaultLang, "theChallenge.heroSubtitle")}
  heroTitleKey="theChallenge.heroTitle"
  heroSubtitleKey="theChallenge.heroSubtitle"
>
  <!-- Stats -->
  <section class="border-b border-stone-800">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-16">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="border-l-2 border-amber-500/40 pl-4">
          <p class="font-display text-4xl lg:text-5xl font-bold text-stone-100">
            ~12
          </p>
          <p
            class="text-stone-500 text-sm mt-1 font-body"
            data-i18n="stats.totalDays"
          >
          </p>
        </div>
        <div class="border-l-2 border-amber-500/40 pl-4">
          <p class="font-display text-4xl lg:text-5xl font-bold text-stone-100">
            ~1,000
          </p>
          <p
            class="text-stone-500 text-sm mt-1 font-body"
            data-i18n="stats.kilometres"
          >
          </p>
        </div>
        <div class="border-l-2 border-amber-500/40 pl-4">
          <p class="font-display text-4xl lg:text-5xl font-bold text-stone-100">
            ~22,000
          </p>
          <p
            class="text-stone-500 text-sm mt-1 font-body"
            data-i18n="stats.metresOfClimbing"
          >
          </p>
        </div>
        <div class="border-l-2 border-amber-500/40 pl-4">
          <p class="font-display text-4xl lg:text-5xl font-bold text-amber-400">
            ~2.5×
          </p>
          <p
            class="text-stone-500 text-sm mt-1 font-body"
            data-i18n="stats.heightOfEverest"
          >
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Challenge Description -->
  <section>
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 lg:py-40">
      <div class="max-w-3xl">
        <p
          class="text-stone-300 text-xl leading-relaxed font-body"
          data-i18n="theChallenge.introDesc"
        >
        </p>
      </div>

      <!-- Route sections -->
      <div class="mt-20 space-y-16">
        <!-- Shared Journey -->
        <div class="grid lg:grid-cols-12 gap-12">
          <div class="lg:col-span-4">
            <span
              class="text-amber-500 font-body text-xs tracking-[0.3em] uppercase"
              data-i18n="theChallenge.styleTag"></span>
            <h2
              class="font-display text-3xl lg:text-4xl font-bold text-stone-100 mt-3"
              data-i18n="theChallenge.styleTitle"
            >
            </h2>
          </div>
          <div class="lg:col-span-8">
            <p
              class="text-stone-400 text-lg leading-relaxed font-body"
              data-i18n="theChallenge.styleDesc1"
            >
            </p>
            <p
              class="text-stone-500 text-lg leading-relaxed font-body mt-4"
              data-i18n="theChallenge.styleDesc2"
            >
            </p>
          </div>
        </div>

        <div class="h-px bg-stone-800"></div>

        <!-- 01 The Start -->
        <div class="grid lg:grid-cols-12 gap-12">
          <div class="lg:col-span-4">
            <div class="bg-stone-900 rounded-2xl p-6 border border-stone-800">
              <span
                class="text-amber-500/50 font-display text-4xl font-bold"
                data-i18n="theChallenge.theStartNum"></span>
              <h3
                class="font-display text-2xl font-bold text-stone-100 mt-2"
                data-i18n="theChallenge.theStartTitle"
              >
              </h3>
              <div class="mt-4 space-y-2">
                <div class="flex justify-between text-sm font-body">
                  <span
                    class="text-stone-500"
                    data-i18n="theChallenge.direction"></span>
                  <span
                    class="text-stone-300"
                    data-i18n="theChallenge.theStartDirection"></span>
                </div>
                <div class="flex justify-between text-sm font-body">
                  <span class="text-stone-500" data-i18n="theChallenge.distance"
                  ></span>
                  <span
                    class="text-stone-300"
                    data-i18n="theChallenge.theStartDistance"></span>
                </div>
                <div class="flex justify-between text-sm font-body">
                  <span
                    class="text-stone-500"
                    data-i18n="theChallenge.elevationGain"></span>
                  <span
                    class="text-stone-300"
                    data-i18n="theChallenge.theStartElevationGain"></span>
                </div>
                <div class="flex justify-between text-sm font-body">
                  <span class="text-stone-500" data-i18n="theChallenge.terrain"
                  ></span>
                  <span
                    class="text-stone-300"
                    data-i18n="theChallenge.theStartTerrain"></span>
                </div>
              </div>
            </div>
          </div>
          <div class="lg:col-span-8 flex items-center">
            <div>
              <p
                class="text-stone-400 text-lg leading-relaxed font-body"
                data-i18n="theChallenge.theStartDesc"
              >
              </p>
            </div>
          </div>
        </div>

        <div class="h-px bg-stone-800"></div>

        <!-- 02 The Climbing -->
        <div class="grid lg:grid-cols-12 gap-12">
          <div class="lg:col-span-4">
            <div class="bg-stone-900 rounded-2xl p-6 border border-stone-800">
              <span
                class="text-amber-500/50 font-display text-4xl font-bold"
                data-i18n="theChallenge.theClimbingNum"></span>
              <h3
                class="font-display text-2xl font-bold text-stone-100 mt-2"
                data-i18n="theChallenge.theClimbingTitle"
              >
              </h3>
              <div class="mt-4 space-y-2">
                <div class="flex justify-between text-sm font-body">
                  <span
                    class="text-stone-500"
                    data-i18n="theChallenge.direction"></span>
                  <span
                    class="text-stone-300"
                    data-i18n="theChallenge.theClimbingDirection"></span>
                </div>
                <div class="flex justify-between text-sm font-body">
                  <span class="text-stone-500" data-i18n="theChallenge.distance"
                  ></span>
                  <span
                    class="text-stone-300"
                    data-i18n="theChallenge.theClimbingDistance"></span>
                </div>
                <div class="flex justify-between text-sm font-body">
                  <span
                    class="text-stone-500"
                    data-i18n="theChallenge.elevationGain"></span>
                  <span
                    class="text-stone-300"
                    data-i18n="theChallenge.theClimbingElevationGain"></span>
                </div>
                <div class="flex justify-between text-sm font-body">
                  <span class="text-stone-500" data-i18n="theChallenge.terrain"
                  ></span>
                  <span
                    class="text-stone-300"
                    data-i18n="theChallenge.theClimbingTerrain"></span>
                </div>
              </div>
            </div>
          </div>
          <div class="lg:col-span-8 flex items-center">
            <div>
              <p
                class="text-stone-400 text-lg leading-relaxed font-body"
                data-i18n="theChallenge.theClimbingDesc"
              >
              </p>
            </div>
          </div>
        </div>

        <div class="h-px bg-stone-800"></div>

        <!-- 03 The Finish -->
        <div class="grid lg:grid-cols-12 gap-12">
          <div class="lg:col-span-4">
            <div class="bg-stone-900 rounded-2xl p-6 border border-stone-800">
              <span
                class="text-amber-500/50 font-display text-4xl font-bold"
                data-i18n="theChallenge.theFinishNum"></span>
              <h3
                class="font-display text-2xl font-bold text-stone-100 mt-2"
                data-i18n="theChallenge.theFinishTitle"
              >
              </h3>
              <div class="mt-4 space-y-2">
                <div class="flex justify-between text-sm font-body">
                  <span
                    class="text-stone-500"
                    data-i18n="theChallenge.direction"></span>
                  <span
                    class="text-stone-300"
                    data-i18n="theChallenge.theFinishDirection"></span>
                </div>
                <div class="flex justify-between text-sm font-body">
                  <span class="text-stone-500" data-i18n="theChallenge.distance"
                  ></span>
                  <span
                    class="text-stone-300"
                    data-i18n="theChallenge.theFinishDistance"></span>
                </div>
                <div class="flex justify-between text-sm font-body">
                  <span
                    class="text-stone-500"
                    data-i18n="theChallenge.elevationGain"></span>
                  <span
                    class="text-stone-300"
                    data-i18n="theChallenge.theFinishElevationGain"></span>
                </div>
                <div class="flex justify-between text-sm font-body">
                  <span class="text-stone-500" data-i18n="theChallenge.terrain"
                  ></span>
                  <span
                    class="text-stone-300"
                    data-i18n="theChallenge.theFinishTerrain"></span>
                </div>
              </div>
            </div>
          </div>
          <div class="lg:col-span-8 flex items-center">
            <div>
              <p
                class="text-stone-400 text-lg leading-relaxed font-body"
                data-i18n="theChallenge.theFinishDesc"
              >
              </p>
            </div>
          </div>
        </div>

        <div class="h-px bg-stone-800"></div>

        <!-- 04 The Homecoming -->
        <div class="grid lg:grid-cols-12 gap-12">
          <div class="lg:col-span-4">
            <div class="bg-stone-900 rounded-2xl p-6 border border-stone-800">
              <span
                class="text-amber-500/50 font-display text-4xl font-bold"
                data-i18n="theChallenge.theHomecomingNum"></span>
              <h3
                class="font-display text-2xl font-bold text-stone-100 mt-2"
                data-i18n="theChallenge.theHomecomingTitle"
              >
              </h3>
              <div class="mt-4 space-y-2">
                <div class="flex justify-between text-sm font-body">
                  <span
                    class="text-stone-500"
                    data-i18n="theChallenge.direction"></span>
                  <span
                    class="text-stone-300"
                    data-i18n="theChallenge.theHomecomingDirection"></span>
                </div>
                <div class="flex justify-between text-sm font-body">
                  <span
                    class="text-stone-500"
                    data-i18n="theChallenge.theHomecomingDistance"></span>
                  <span
                    class="text-stone-300"
                    data-i18n="theChallenge.theHomecomingDistance"></span>
                </div>
                <div class="flex justify-between text-sm font-body">
                  <span
                    class="text-stone-500"
                    data-i18n="theChallenge.theHomecomingElevationGain"></span>
                  <span
                    class="text-stone-300"
                    data-i18n="theChallenge.theHomecomingElevationGain"></span>
                </div>
                <div class="flex justify-between text-sm font-body">
                  <span
                    class="text-stone-500"
                    data-i18n="theChallenge.theHomecomingTerrain"></span>
                  <span
                    class="text-stone-300"
                    data-i18n="theChallenge.theHomecomingTerrain"></span>
                </div>
              </div>
            </div>
          </div>
          <div class="lg:col-span-8 flex items-center">
            <div>
              <p
                class="text-stone-400 text-lg leading-relaxed font-body"
                data-i18n="theChallenge.theHomecomingDesc"
              >
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-24 text-center">
        <a
          href="/donate"
          class="inline-flex items-center gap-2 bg-amber-500 text-stone-950 px-10 py-4 rounded-full font-body font-bold hover:bg-amber-400 transition-colors"
        >
          <span data-i18n="theChallenge.supportChallenge"></span>
        </a>
      </div>
    </div>
  </section>
</PageLayout>
